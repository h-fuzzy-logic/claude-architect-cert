# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Required: Anthropic API key for all Claude API calls
ANTHROPIC_API_KEY=your-api-key-here

# Optional: loguru log level (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
LOG_LEVEL=INFO

# Optional: set to 1 to enable integration tests that make real API calls
# Usage: INTEGRATION=1 pytest tests/integration/ -v
INTEGRATION=0
